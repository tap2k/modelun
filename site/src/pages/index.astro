---
import Base from '../layouts/Base.astro';
import { renderEssay } from '../lib/essay.js';
const essayHtml = renderEssay();
---

<Base title="A field guide to how language models behave under pressure">
  <article class="essay" set:html={essayHtml} />
</Base>

<style>
  .essay :global(h1) { margin-bottom: 1.5rem; }
  .essay :global(em) { color: #444; }
  .essay :global(a.model-link) { color: var(--fg); text-decoration: none; border-bottom: 1px dotted var(--accent); }
  .essay :global(a.model-link:hover) { color: var(--accent); }
  .essay :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2.5rem 0; }
  .essay :global(blockquote) { font-style: italic; }
</style>
