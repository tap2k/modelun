---
import Base from '../../layouts/Base.astro';
import { modelsByGroup } from '../../lib/atlas.js';
const groups = modelsByGroup();
---

<Base title="Bestiary — Personality Atlas">
  <h1>The bestiary</h1>
  <p class="muted">
    Models grouped by behavioral type — the unit is the tell, models are the exhibits.
  </p>

  {groups.map((g) => (
    <section id={g.group} class="group">
      <h2>{g.group} <span class="muted">({g.models.length})</span></h2>
      <p class="desc">{g.desc}</p>
      <div class="members">
        {g.models.map((m) => (
          <a class="member" href={`/model/${m.slug}/`}>
            <span class="name">{m.slug}</span>
            {m.portrait?.signature && <span class="sig">“{m.portrait.signature}”</span>}
          </a>
        ))}
      </div>
    </section>
  ))}
</Base>

<style>
  .group { margin-bottom: 2rem; scroll-margin-top: 5rem; }
  .desc { font-size: 1.02rem; color: #333; margin-top: -.4rem; }
  .members { display: flex; flex-direction: column; gap: .4rem; }
  .member {
    display: block; text-decoration: none; color: var(--fg);
    border: 1px solid var(--line); border-radius: 8px; padding: .55rem .75rem; background: #fff;
  }
  .member:hover { border-color: var(--accent); }
  .name { font-weight: 600; }
  .sig { display: block; color: var(--muted); font-size: .9rem; }
</style>
