---
const { title = 'Personality Atlas' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-head">
      <a href="/" class="brand">Personality Atlas</a>
      <nav>
        <a href="/">Essay</a>
        <a href="/bestiary/">Bestiary</a>
        <a href="/models/">Models</a>
        <a href="/methodology/">Methodology</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <a href="https://github.com/tap2k/modelun">Source &amp; data on GitHub</a>
    </footer>

    <style is:global>
      :root {
        --fg: #1a1a1a; --muted: #6b6b6b; --bg: #fbfbf9; --line: #e3e1da;
        --accent: #8a5a00; --mark: #fff3c4; --chip: #f0eee8;
        --max: 760px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; color: var(--fg); background: var(--bg);
        font: 16px/1.65 -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      }
      main { max-width: var(--max); margin: 0 auto; padding: 1rem 1.25rem 4rem; }
      .site-head {
        display: flex; align-items: baseline; gap: 1.5rem;
        max-width: var(--max); margin: 0 auto; padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--line);
      }
      .brand { font-weight: 700; text-decoration: none; color: var(--fg); }
      nav { display: flex; gap: 1rem; }
      nav a, .brand { color: var(--fg); }
      a { color: var(--accent); }
      footer {
        max-width: var(--max); margin: 0 auto; padding: 2rem 1.25rem;
        color: var(--muted); font-size: .85rem; border-top: 1px solid var(--line);
      }
      h1 { font-size: 1.9rem; line-height: 1.2; }
      h2 { font-size: 1.4rem; margin-top: 2.5rem; }
      blockquote {
        margin: .6rem 0; padding: .4rem 0 .4rem 1rem;
        border-left: 3px solid var(--line); color: #333;
      }
      code { background: var(--chip); padding: .05em .35em; border-radius: 4px; font-size: .9em; }
      .chip {
        display: inline-block; background: var(--chip); border: 1px solid var(--line);
        border-radius: 999px; padding: .1rem .6rem; font-size: .8rem; text-decoration: none;
        color: var(--fg); margin: .15rem .2rem .15rem 0;
      }
      .muted { color: var(--muted); }
    </style>
  </body>
</html>
