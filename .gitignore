# runs/ and cards/ are disposable working output — regenerate at will, not committed.
# The published dataset is committed under studies/conduct/data/ (see its MANIFEST.md).
# Root working dirs are gitignored; the curated basis is committed under studies/conduct/bottom-up/
# (the /cards/ rule below is root-anchored, so bottom-up/cards is NOT swept up by these patterns).
/runs/*
!/runs/.gitkeep
/cards/

# labels (judge output, Contract B) + reads/grids — regenerable working output per study.
# The adjudicated store (data/benchmark/markers.json) is committed; raw labels are not.
studies/*/markers/
studies/*/markers-unclamped/
studies/*/reads/

# memory/ — agent-private notes, not project content.
memory/

# secrets
.env

# python
.venv/
venv/
__pycache__/
*.pyc

# macOS
.DS_Store

# viewer — index.html + build.py + harness/viewer/core.js are source;
# data.js (the bundled blob), the copied core.js, and the copied grid are generated.
studies/*/views/data.js
studies/*/views/core.js
studies/*/views/markers_grid.png

# site/ — the combined Pages tree, assembled by .github/workflows/pages.yml (cp -r of the
# view dirs into per-study slugs). A build artifact, regenerated on every deploy — not source.
/site/

# promptfoo trial — local scratch reference, not an adopted tool (see docs/harness.md)
studies/*/promptfoo/
