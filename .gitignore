# runs/ and cards/ are disposable working output — regenerate at will, not committed.
# The ONE published run is promoted to data/ (committed) as the canonical dataset the
# essay + synthesis cite; see data/benchmark/MANIFEST.md. Keep new scratch runs here.
runs/*
!runs/.gitkeep
cards/

# reads/ — multi-reader synthesis JSON, regenerable via scout/run_reads.py (see synthesis §6).
reads/

# markers/ — per-judge binary-marker labels, regenerable via scout/run_markers.py.
# The adjudicated result is promoted to data/benchmark/markers.json (committed). See docs/method/markers.md.
markers/

# memory/ — agent-private notes, not project content.
memory/

# secrets
.env

# python
.venv/
venv/
__pycache__/
*.pyc

# macOS
.DS_Store

# site/ — generated data blob + Astro build artifacts (the parser + data/ are source of truth)
site/src/data/atlas.json
site/node_modules/
site/dist/
site/.astro/
